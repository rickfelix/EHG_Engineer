# EHG_Engineer Environment Configuration Example
# Copy this file to .env and add your actual values
#
# DR NOTE (SD-LEO-INFRA-RESILIENCE-REVIEW-SPECIAL-001 / FR-3): this file is the
# SECRETS INVENTORY for machine-loss recovery. It lists every key name present
# in the live .env plus the distinct .env.claude keys, each with its re-issue
# source. Values are NEVER stored here — to rebuild .env on a new machine,
# walk this file top to bottom re-issuing each key from the named source
# (rotation procedures: docs/security/key-rotation-runbook.md; full recovery
# walkthrough: ops/runbooks/disaster-recovery.md).

# ==============================================================================
# SUPABASE — project dedlbzhpgkmetvhbkyzq (consolidated DB)
# Re-issue source: Supabase Dashboard > Project Settings (API / Database)
# ==============================================================================

# Project URL + anon key (Dashboard > Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Service Role Key (Server-Side Scripts Only)
# ⚠️  SECURITY WARNING: This key bypasses ALL RLS policies
# - NEVER expose to client-side code
# - NEVER commit to version control
# - Only use in server-side scripts
#
# USE THIS KEY FOR:
# - Reading protected data (handoffs, sub-agent results) in scripts
# - Server-side operations requiring authenticated access
# - Bypassing RLS policies for admin operations
#
# GET YOUR KEY FROM: Supabase Dashboard > Project Settings > API > service_role key
# SCRIPTS: Use createSupabaseServiceClient() from scripts/lib/supabase-connection.js
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database password for direct pg connections (scripts/lib/supabase-connection.js)
# Re-issue: Dashboard > Project Settings > Database > Reset database password
SUPABASE_DB_PASSWORD=see-supabase-dashboard-database-settings

# JWT secret (verifying/minting tokens in server-side tooling)
# Re-issue: Dashboard > Project Settings > API > JWT Settings
SUPABASE_JWT_SECRET=see-supabase-dashboard-api-settings

# Restricted schema-reader key (read-only schema introspection tooling)
# Re-issue: Supabase Dashboard (restricted key) or re-provision the reader role
SUPABASE_SCHEMA_READER_KEY=see-supabase-dashboard

# Supabase Connection Pooler (Required for DDL Migrations)
# Used by lib/connection-router.js for direct pg.Client connections
# GET YOUR URL FROM: Supabase Dashboard > Project Settings > Database > Connection Pooling
SUPABASE_POOLER_URL=your-pooler-url-here

# TLS trust for the pooler chain on Windows (path to the committed CA bundle —
# certs/supabase-root-2021-ca.pem; see scripts/lib/supabase-connection.js)
SUPABASE_SSL_CA=certs/supabase-root-2021-ca.pem
NODE_EXTRA_CA_CERTS=certs/supabase-root-2021-ca.pem

# RLS Policy Verification (Security Infrastructure)
# Connection string for rls_auditor role - read-only access to pg_policies
# Security: SELECT-only on pg_policies and information_schema.tables
# Rotation: Every 90 days (documented in database/migrations/create-rls-auditor-role.sql)
# Usage: scripts/verify-rls-policies.js and GitHub Actions workflow
SUPABASE_RLS_AUDITOR_URL=your-rls-auditor-url-here

# EHG Application Database aliases (same consolidated project)
EHG_SUPABASE_URL=https://your-project-id.supabase.co
EHG_SUPABASE_ANON_KEY=your-ehg-anon-key
EHG_SUPABASE_SERVICE_ROLE_KEY=your-ehg-service-role-key

# ==============================================================================
# LLM / AI PROVIDERS
# ==============================================================================

# Anthropic API key (Claude API usage outside the Claude Code harness)
# Re-issue: https://console.anthropic.com/ > API Keys
ANTHROPIC_API_KEY=see-anthropic-console

# Google Gemini API Key (Primary — used for all LLM, embedding, and vision tasks)
# Re-issue: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# OpenAI API Key (Secondary fallback — also needed for voice/WebRTC features)
# Re-issue: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Provider routing + model pins (config, not secrets)
LLM_PROVIDER=google
GEMINI_MODEL=auto
GEMINI_MODEL_REASONING=auto

# Vision QA Configuration (Optional)
AI_PROVIDER=google              # 'google', 'openai', or 'anthropic' (default: google)
AI_MODEL=auto                   # 'auto' for automatic model selection (recommended)

# Optional: Set specific model if you don't want auto-selection
# AI_MODEL=gemini-3.1-pro-preview    # Most accurate (default for validation/generation)
# AI_MODEL=gemini-3-flash-preview    # Balanced performance/cost (default for fast ops)
# AI_MODEL=gpt-5.2                   # OpenAI fallback
# AI_MODEL=claude-sonnet-4-20250514  # Anthropic option

# Optional: Default cost limits for Vision QA
# VISION_QA_DEFAULT_COST_LIMIT=2.00
# VISION_QA_MAX_ITERATIONS=30
# VISION_QA_CONSENSUS_RUNS=1

# ==============================================================================
# LOCAL LLM CONFIGURATION (Ollama - Haiku Replacement)
# ==============================================================================
# Use local LLM via Ollama instead of cloud Haiku for cost savings
# Requires Ollama running locally: ollama serve
# Falls back to cloud Haiku automatically if Ollama unavailable

# Enable local LLM for Haiku-class tasks (classification, fast ops)
USE_LOCAL_LLM=false

# Ollama server URL (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# Local model to use (default: qwen3-coder:30b - benchmarked best for Haiku tasks)
# OLLAMA_MODEL=qwen3-coder:30b

# Disable automatic fallback to cloud Haiku (default: true = fallback enabled)
# OLLAMA_FALLBACK_ENABLED=true

# Request timeout in milliseconds (default: 30000)
# OLLAMA_TIMEOUT_MS=30000

# ==============================================================================
# THIRD-PARTY SERVICES
# ==============================================================================

# Email via Resend (alerts + notify pipelines)
# Re-issue: https://resend.com dashboard > API Keys
RESEND_API_KEY=re_see-resend-dashboard

# Operator notification addresses (not secrets)
CLAUDE_NOTIFY_EMAIL=operator@yourdomain.com
SOVEREIGN_ALERT_EMAIL=chairman@yourdomain.com

# Discord Webhook (Sovereign alert system)
# Re-issue: Discord Server Settings > Integrations > Webhooks > New Webhook
DISCORD_ALERT_WEBHOOK=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Todoist (EVA idea pipeline)
# Re-issue: https://todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=your-todoist-api-token

# Google OAuth (YouTube integration)
# Re-issue: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# YouTube Data API key
# Re-issue: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=see-google-cloud-console

# Sentry (error + cron monitoring)
# Re-issue: https://sentry.io > Settings > Auth Tokens / Projects > DSN
SENTRY_ORG=your-sentry-org-slug
SENTRY_AUTH_TOKEN=see-sentry-settings-auth-tokens
SENTRY_CRONREAD_DSN=see-sentry-project-dsn

# Stitch (Google design tool) API key
# Re-issue: Stitch dashboard
STITCH_API_KEY=see-stitch-dashboard

# ==============================================================================
# SERVER / DASHBOARD / TEST HARNESS (config, not secrets)
# ==============================================================================

BASE_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Internal admin API key (self-issued — generate a fresh random value on rebuild;
# no external provider involved)
ADMIN_API_KEY=generate-a-fresh-random-value

TEST_TIMEOUT=30000
TEST_RETRIES=2
ENABLE_LIVE_TEST_EXECUTION=false
PLAYWRIGHT_GATE_TIMEOUT_MS=600000
CI_TEARDOWN_PERSIST=false

# Gate scoring strictness toggle (Russian-judge calibration)
RUSSIAN_JUDGE_ENABLED=true

# Claude Code harness behavior toggle
CLAUDE_CODE_DISABLE_BACKGROUND_TASKS=false

# Telemetry auto-analysis loop toggle
TELEMETRY_AUTO_ANALYSIS_ENABLED=false

# Worktree reaper: execute mode (false = dry-run)
WORKTREE_REAPER_EXECUTE=false

# Project Configuration
LEO_PROTOCOL_VERSION=4.3.3
PROJECT_NAME=EHG_Engineer

# Development Environment (Optional)
NODE_ENV=development
DEBUG=vision-qa:*              # Enable debug logging for Vision QA

# ==============================================================================
# SESSION IDENTITY SINGLE SOURCE OF TRUTH (SD-LEO-PROTOCOL-INFRASTRUCTURE-RELATIONSHIPAWARE-ORCH-001-B)
# ==============================================================================
# Controls the three-source identity reconciliation + claim-validity-gate agreement
# check. Default OFF during burn-in.
#   unset / false / 0 / no / off  → legacy behavior (env var written first, no pointer,
#                                    gate does not enforce source agreement)
#   true / 1 / yes / on           → canonical marker written before env var (FR-4),
#                                    .claude/session-identity/current pointer maintained,
#                                    claim-validity-gate fails closed on source disagreement
#                                    (FR-2, FR-3) while treating single-source-present as valid.
# See .claude/session-identity/README.md for the full contract and promotion criteria.
SESSION_IDENTITY_SOT_ENABLED=false

# EVA Periodic Vision Scoring Scheduler (SD-LEO-INFRA-VISION-PERIODIC-SCORER-001)
# Set to 'true' to enable automated periodic vision scoring via eva-master-scheduler.js
# When enabled: start the scheduler with: node scripts/eva-scheduler.js start
# Without this flag, the scheduler silently skips vision scoring even when running.
# VISION_PERIODIC_SCORING_ENABLED=true

# ==============================================================================
# SD-LEO-INFRA-EVA-STAGE-WORKER-001 — Vision Repair Loop (FR-4 / FR-5)
# ==============================================================================
# Bounded LLM repair loop for eva_vision_documents that fail trigger-validated
# quality_checked. See lib/eva/vision-repair-loop.js.
#
# Per-venture override stored in eva_venture_config table; key formats:
#   global: 'vision_repair_loop_enabled' (jsonb boolean)
#   per-venture: 'venture:<uuid>:vision_repair_loop_enabled' (jsonb boolean)
# Per-venture OFF beats global ON; env var beats both.
LEO_VISION_REPAIR_LOOP_ENABLED=false

# Cumulative session token budget (FR-5). Default 540800 = 65 currently-failing
# rows × 8000-token regen estimate × 1.04 safety margin (PLAN-derived from FR-8
# diagnostic SQL on 2026-04-29). Loop exits cleanly with non-blocking warning
# when cumulative usage exceeds this cap.
LEO_VISION_REPAIR_LOOP_TOKEN_BUDGET=540800

# SD-LEO-INFRA-SURFACE-INERT-WORKER-001 — surface inert worker-revival to the operator (default-OFF)
# When true, the stale-session sweep flags aged-unconsumed pending worker_spawn_requests and emits
# ONE de-duped operator alert carrying the paste-able fleet-worker /loop wake prompt. Read-only, fail-open.
SURFACE_INERT_WORKER_V1=false
# Minimum requested_at age (minutes) before a pending unfulfilled spawn request is flagged.
INERT_WORKER_AGE_MIN=360

# ==============================================================================
# .env.claude DISTINCT KEYS (separate file — see .env.claude.example)
# ==============================================================================
# .env.claude configures the Claude-mode server/agent layer. It shares
# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY / RESEND_API_KEY / CLAUDE_NOTIFY_EMAIL
# with .env (re-issue sources above). Its DISTINCT keys are all non-secret
# policy/config toggles — recoverable from this inventory without visiting any
# provider dashboard:
#
#   Server:        PORT, NODE_ENV, API_MODE, MAX_TOKENS, TEMPERATURE
#   Mode gates:    ENABLE_CLAUDE_MODE, ENABLE_WRITE_OPERATIONS, ENABLE_DATABASE_WRITES,
#                  READ_ONLY_MODE, ALLOW_MIGRATIONS, ALLOW_SCHEMA_CHANGES
#   Governance:    ENFORCE_SIGNATURES, REQUIRE_ATTESTATIONS, PLAN_SUPERVISOR_MIN_CONFIDENCE,
#                  STORY_GATE_REQUIRED, VERIFY_PROVENANCE, VERIFY_SBOM, ENFORCE_DIGESTS,
#                  SLSA_LEVEL_REQUIRED, ARTIFACT_FORMAT, SBOM_FORMAT, PROVENANCE_FORMAT,
#                  PROVENANCE_PREDICATE
#   Git/GitOps:    ALLOWED_BRANCH_PREFIX, APPLY_MARKER, VALIDATE_MERGE_BASE,
#                  GITOPS_OPERATOR, ADMISSION_CONTROLLER, RECONCILIATION_INTERVAL
#   Policy engine: POLICY_ENGINE, ENFORCE_POLICIES, BLOCK_UNSIGNED_IMAGES,
#                  BLOCK_NON_DIGEST_IMAGES, REQUIRE_SLSA_PROVENANCE
#   Logging:       LOG_LEVEL, LOG_FORMAT, AUDIT_LOG_ENABLED
#   Tooling:       ALLOWED_TOOLS, DENIED_TOOLS
