            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/rickf/Projects/_EHG/EHG_Engineer/scripts/hooks/migration-execution-reminder.cjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "npx eslint --fix --no-error-on-unmatched-pattern \"$CLAUDE_FILE_PATHS\" 2>&1 | tail -5",
            "timeout": 15,
            "statusMessage": "Linting..."
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx eslint --fix --no-error-on-unmatched-pattern \"$CLAUDE_FILE_PATHS\" 2>&1 | tail -5",
            "timeout": 15,
            "statusMessage": "Linting..."
          }
        ]
      },
      {
        "matcher": "Read",
