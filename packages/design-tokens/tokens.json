{
  "$schema": "./ehg-design-tokens.schema.json",
  "version": "1.0.0",
  "description": "EHG Design Token System - Three-tier hierarchy (brand, semantic, component)",
  "brand": {
    "colors": {
      "--ehg-brand-navy": "215 100% 8%",
      "--ehg-brand-blue": "217 91% 50%",
      "--ehg-brand-blue-light": "220 100% 70%",
      "--ehg-brand-blue-lighter": "220 100% 95%",
      "--ehg-brand-white": "0 0% 100%",
      "--ehg-brand-black": "215 25% 8%",
      "--ehg-brand-gray-50": "210 40% 98%",
      "--ehg-brand-gray-100": "214 32% 91%",
      "--ehg-brand-gray-200": "220 13% 91%",
      "--ehg-brand-gray-500": "215 20% 40%",
      "--ehg-brand-gray-700": "215 25% 15%",
      "--ehg-brand-gray-900": "215 25% 8%",
      "--ehg-brand-success": "142 76% 30%",
      "--ehg-brand-success-light": "142 76% 36%",
      "--ehg-brand-warning": "43 96% 56%",
      "--ehg-brand-danger": "0 84% 50%",
      "--ehg-brand-danger-light": "0 84% 60%"
    },
    "typography": {
      "--ehg-brand-font-sans": "Inter, system-ui, sans-serif",
      "--ehg-brand-font-mono": "JetBrains Mono, Consolas, monospace"
    },
    "spacing": {
      "--ehg-brand-spacing-unit": "0.25rem"
    },
    "radius": {
      "--ehg-brand-radius-base": "0.75rem"
    }
  },
  "semantic": {
    "colors": {
      "light": {
        "--color-background": { "$ref": "--ehg-brand-white" },
        "--color-foreground": { "$ref": "--ehg-brand-gray-700" },
        "--color-primary": { "$ref": "--ehg-brand-blue" },
        "--color-primary-foreground": { "$ref": "--ehg-brand-white" },
        "--color-primary-glow": "220 100% 70%",
        "--color-secondary": { "$ref": "--ehg-brand-gray-50" },
        "--color-secondary-foreground": { "$ref": "--ehg-brand-gray-700" },
        "--color-muted": { "$ref": "--ehg-brand-gray-50" },
        "--color-muted-foreground": { "$ref": "--ehg-brand-gray-500" },
        "--color-accent": "217 91% 59%",
        "--color-accent-foreground": { "$ref": "--ehg-brand-white" },
        "--color-success": { "$ref": "--ehg-brand-success" },
        "--color-success-foreground": { "$ref": "--ehg-brand-white" },
        "--color-warning": { "$ref": "--ehg-brand-warning" },
        "--color-warning-foreground": { "$ref": "--ehg-brand-white" },
        "--color-destructive": { "$ref": "--ehg-brand-danger" },
        "--color-destructive-foreground": { "$ref": "--ehg-brand-white" },
        "--color-border": { "$ref": "--ehg-brand-gray-100" },
        "--color-input": { "$ref": "--ehg-brand-gray-100" },
        "--color-ring": { "$ref": "--ehg-brand-blue" }
      },
      "dark": {
        "--color-background": { "$ref": "--ehg-brand-gray-900" },
        "--color-foreground": "0 0% 98%",
        "--color-primary": { "$ref": "--ehg-brand-blue-light" },
        "--color-primary-foreground": { "$ref": "--ehg-brand-gray-900" },
        "--color-primary-glow": "217 91% 59%",
        "--color-secondary": "215 25% 15%",
        "--color-secondary-foreground": "0 0% 98%",
        "--color-muted": "215 25% 12%",
        "--color-muted-foreground": "215 20% 65%",
        "--color-accent": "215 25% 15%",
        "--color-accent-foreground": "0 0% 98%",
        "--color-success": "142 71% 45%",
        "--color-success-foreground": "0 0% 98%",
        "--color-warning": "43 96% 60%",
        "--color-warning-foreground": { "$ref": "--ehg-brand-black" },
        "--color-destructive": "0 62% 60%",
        "--color-destructive-foreground": "0 0% 98%",
        "--color-border": "215 25% 15%",
        "--color-input": "215 25% 15%",
        "--color-ring": { "$ref": "--ehg-brand-blue-light" }
      }
    },
    "typography": {
      "--font-sans": { "$ref": "--ehg-brand-font-sans" },
      "--font-mono": { "$ref": "--ehg-brand-font-mono" }
    },
    "spacing": {
      "--spacing-xs": "0.25rem",
      "--spacing-sm": "0.5rem",
      "--spacing-md": "1rem",
      "--spacing-lg": "1.5rem",
      "--spacing-xl": "2rem",
      "--spacing-2xl": "3rem"
    },
    "radius": {
      "--radius-none": "0",
      "--radius-sm": "0.375rem",
      "--radius-md": "0.5rem",
      "--radius-lg": { "$ref": "--ehg-brand-radius-base" },
      "--radius-xl": "1rem",
      "--radius-full": "9999px"
    },
    "shadow": {
      "--shadow-sm": "0 1px 3px 0 hsl(215 25% 15% / 0.1), 0 1px 2px 0 hsl(215 25% 15% / 0.06)",
      "--shadow-md": "0 4px 6px -1px hsl(215 25% 15% / 0.1), 0 2px 4px -1px hsl(215 25% 15% / 0.06)",
      "--shadow-lg": "0 10px 15px -3px hsl(215 25% 15% / 0.1), 0 4px 6px -2px hsl(215 25% 15% / 0.05)",
      "--shadow-xl": "0 20px 25px -5px hsl(215 25% 15% / 0.1), 0 10px 10px -5px hsl(215 25% 15% / 0.04)"
    },
    "motion": {
      "--transition-fast": "150ms cubic-bezier(0.4, 0, 0.2, 1)",
      "--transition-normal": "300ms cubic-bezier(0.4, 0, 0.2, 1)",
      "--transition-slow": "500ms cubic-bezier(0.4, 0, 0.2, 1)",
      "--transition-bounce": "400ms cubic-bezier(0.175, 0.885, 0.32, 1.275)"
    }
  },
  "component": {
    "button": {
      "--button-bg": { "$ref": "--color-primary" },
      "--button-fg": { "$ref": "--color-primary-foreground" },
      "--button-border": "transparent",
      "--button-radius": { "$ref": "--radius-md" },
      "--button-padding-x": { "$ref": "--spacing-md" },
      "--button-padding-y": { "$ref": "--spacing-sm" },
      "--button-hover-opacity": "0.9",
      "--button-disabled-opacity": "0.5"
    },
    "card": {
      "--card-bg": { "$ref": "--color-background" },
      "--card-fg": { "$ref": "--color-foreground" },
      "--card-border": { "$ref": "--color-border" },
      "--card-radius": { "$ref": "--radius-lg" },
      "--card-padding": { "$ref": "--spacing-lg" },
      "--card-shadow": { "$ref": "--shadow-sm" }
    },
    "input": {
      "--input-bg": { "$ref": "--color-background" },
      "--input-fg": { "$ref": "--color-foreground" },
      "--input-border": { "$ref": "--color-input" },
      "--input-radius": { "$ref": "--radius-md" },
      "--input-padding-x": { "$ref": "--spacing-md" },
      "--input-padding-y": { "$ref": "--spacing-sm" },
      "--input-focus-ring": { "$ref": "--color-ring" }
    },
    "modal": {
      "--modal-bg": { "$ref": "--color-background" },
      "--modal-fg": { "$ref": "--color-foreground" },
      "--modal-border": { "$ref": "--color-border" },
      "--modal-radius": { "$ref": "--radius-xl" },
      "--modal-shadow": { "$ref": "--shadow-xl" },
      "--modal-backdrop": "hsl(0 0% 0% / 0.5)"
    },
    "sidebar": {
      "--sidebar-bg": "0 0% 98%",
      "--sidebar-fg": "240 5.3% 20%",
      "--sidebar-border": "220 13% 91%",
      "--sidebar-accent": "240 4.8% 95.9%",
      "--sidebar-accent-fg": "240 5.9% 10%"
    },
    "tooltip": {
      "--tooltip-bg": { "$ref": "--color-foreground" },
      "--tooltip-fg": { "$ref": "--color-background" },
      "--tooltip-radius": { "$ref": "--radius-sm" },
      "--tooltip-padding": { "$ref": "--spacing-sm" }
    },
    "badge": {
      "--badge-radius": { "$ref": "--radius-full" },
      "--badge-padding-x": { "$ref": "--spacing-sm" },
      "--badge-padding-y": "0.125rem",
      "--badge-font-size": "0.75rem"
    }
  },
  "metadata": {
    "created": "2026-01-30",
    "author": "EHG Design System",
    "sd_id": "SD-LEO-ORCH-AESTHETIC-DESIGN-SYSTEM-001-A"
  }
}
